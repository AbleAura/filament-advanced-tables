{
    "name": "ableaura/filament-advanced-tables",
    "description": "Supercharge your Filament tables with user views, quick filters, multi-sort, advanced search, preset views, favorites bar, and more.",
    "keywords": ["filament", "laravel", "tables", "filters", "views", "advanced"],
    "license": "MIT",
    "authors": [
        {
            "name": "Ableaura",
            "email": "dev@ableaura.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0 || ^4.0",
        "illuminate/contracts": "^10.0 || ^11.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ableaura\\FilamentAdvancedTables\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ableaura\\FilamentAdvancedTables\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ableaura\\FilamentAdvancedTables\\FilamentAdvancedTablesServiceProvider"
            ],
            "aliases": {
                "FilamentAdvancedTables": "Ableaura\\FilamentAdvancedTables\\Facades\\FilamentAdvancedTables"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
